# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/ai_resume_analyzer

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# AI API
# Prefer AI_API_KEY. OPENAI_API_KEY is supported for backward-compatibility.
AI_API_KEY=your-ai-api-key
OPENAI_API_KEY=your-openai-api-key

# File Upload
MAX_FILE_SIZE=5242880

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173
